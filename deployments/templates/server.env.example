# Copy to host-local override (for example .env.local) — do not commit secrets.

SDKWORK_DEPLOYMENT_PROFILE=cloud
SDKWORK_SERVICE_LAYOUT=container
SDKWORK_RUNTIME_TARGET=container
SDKWORK_DOUDIZHU_APP_ROOT=/app/sdkwork-doudizhu

DOUDIZHU_REPOSITORY_MODE=sqlx
DOUDIZHU_DATABASE_URL=postgres://sdkwork:sdkwork@postgres:5432/sdkwork_doudizhu
DOUDIZHU_DATABASE_AUTO_MIGRATE=true

RUST_LOG=info,sdkwork_doudizhu_api_server=debug
DOUDIZHU_API_BIND=0.0.0.0:8096
